//
// Tang Nano 20K — Pin Constraints
// Target: GW2AR-LV18QN88C8/I7
//

//--------------------------------------------------------------------
// Clock — 98.304 MHz from MS5351 (pin 10, configured via BL616 CLI)
//   pll_clk O0=98.304M -s   (one-time setup, persists in MS5351 NVM)
//--------------------------------------------------------------------
IO_LOC  "clk" 10;
IO_PORT "clk" IO_TYPE=LVCMOS33;

//--------------------------------------------------------------------
// Reset button
//--------------------------------------------------------------------
IO_LOC  "rst" 87;
IO_PORT "rst" IO_TYPE=LVCMOS33;

//--------------------------------------------------------------------
// Status LEDs (active low — pull-up, LED on when pin driven low)
//--------------------------------------------------------------------
IO_LOC "led[5]" 20;
IO_PORT "led[5]" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_LOC "led[4]" 19;
IO_PORT "led[4]" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_LOC "led[3]" 18;
IO_PORT "led[3]" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_LOC "led[2]" 17;
IO_PORT "led[2]" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_LOC "led[1]" 16;
IO_PORT "led[1]" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_LOC "led[0]" 15;
IO_PORT "led[0]" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;

//--------------------------------------------------------------------
// Console UART (UART0 — NEORV32 bootloader/debug)
//--------------------------------------------------------------------
IO_LOC  "uart_tx" 69;
IO_LOC  "uart_rx" 70;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33;

//--------------------------------------------------------------------
// MIDI UART (UART1 — 31250 baud MIDI input)
//--------------------------------------------------------------------
IO_LOC  "midi_rx" 28;
IO_PORT "midi_rx" IO_TYPE=LVCMOS33;

//--------------------------------------------------------------------
// I2S Audio Interface (MAX98357A amplifier via built-in DAC)
//--------------------------------------------------------------------
IO_LOC  "i2s_bclk"  56;  // HP_BCK  — bit clock
IO_LOC  "i2s_lrclk" 55;  // HP_WS   — word select / left-right clock
IO_LOC  "i2s_data"  54;  // HP_DIN  — serial data
IO_LOC  "pa_en"     51;  // PA_EN   — amplifier enable (active high)

IO_PORT "i2s_bclk"  PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_PORT "i2s_lrclk" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_PORT "i2s_data"  PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_PORT "pa_en"     PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;

//--------------------------------------------------------------------
// Unused / Reserved — uncomment as needed
//--------------------------------------------------------------------

// SPI Flash (for patch storage — future)
// IO_LOC  "flash_cs_n"  60;
// IO_LOC  "flash_clk"   59;
// IO_LOC  "flash_miso"  62;
// IO_LOC  "flash_mosi"  61;

// SD Card (for sample playback — future)
// IO_LOC  "sd_clk"      83;
// IO_LOC  "sd_cmd"      82;
// IO_LOC  "sd_dat[0]"   84;
// IO_LOC  "sd_dat[1]"   85;
// IO_LOC  "sd_dat[2]"   80;
// IO_LOC  "sd_dat[3]"   81;
